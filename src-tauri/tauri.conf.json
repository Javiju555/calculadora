{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Calculadora",
  "version": "0.1.0",
  "identifier": "com.javiju.calculadora",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1422",
    "beforeDevCommand": "cd ../frontend && ~/.bun/bin/bun run dev --host --port 1422",
    "beforeBuildCommand": "cd ../frontend && ~/.bun/bin/bun run build"
  },
  "app": {
    "enableGTKAppId": true,
    "windows": [
      {
        "title": "Calculadora",
        "label": "main",
        "width": 440,
        "height": 700,
        "minWidth": 380,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "visible": true,
        "center": true,
        "focus": true,
        "zoomHotkeysEnabled": false,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
